PORT=3000
NODE_ENV=development

# MongoDB connection string
# Local: mongodb://localhost:27017/karibu_groceries_db
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/karibu_groceries_db
DATABASE_URI=mongodb://localhost:27017/karibu_groceries_db

# JWT Configuration
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secure_jwt_secret_min_32_characters_long_change_this_in_production
JWT_EXPIRES_IN=8h

# CORS Configuration (comma-separated for multiple origins)
CLIENT_URL=http://localhost:3000

# Email Configuration (for password reset - optional)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
# EMAIL_FROM=noreply@kgl-groceries.com

# Rate Limiting (optional - defaults shown)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
# AUTH_RATE_LIMIT_MAX=5
