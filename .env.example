# =================================
# KGL Groceries Management System
# Environment Configuration Template
# =================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
# Local MongoDB: mongodb://localhost:27017/karibu_groceries_db
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/karibu_groceries_db
DATABASE_URI=mongodb://localhost:27017/karibu_groceries_db

# JWT Security Configuration
# IMPORTANT: Generate strong secrets for production!
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secure-jwt-secret-key-change-this-in-production
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=your-different-refresh-token-secret-key
JWT_REFRESH_EXPIRES_IN=7d

# Email Configuration (Gmail recommended)
# 1. Enable 2FA on Gmail account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use app password below (remove spaces)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# SMS Configuration (Africa's Talking)
# 1. Sign up at https://africastalking.com
# 2. Get API key from dashboard
# 3. Add credits for production SMS
SMS_API_KEY=your-africastalking-api-key
SMS_USERNAME=sandbox
SMS_SENDER_ID=KGL

# Frontend Configuration
CLIENT_URL=http://localhost:3000

# Security Configuration (Optional)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# File Upload Configuration (Optional)
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif

# Logging Configuration (Optional)
LOG_LEVEL=info
LOG_FILE=logs/app.log

# User Seeding Configuration (Development Only)
# Password used when seeding initial users - CHANGE IMMEDIATELY AFTER SEEDING!
DEFAULT_USER_PASSWORD=ChangeMe@2026
