{
	"info": {
		"_postman_id": "kgl-groceries-api-collection",
		"name": "KGL Groceries Management System API",
		"description": "Complete API collection for testing the KGL Groceries Management System.\n\n**Setup Instructions:**\n1. Import this collection into Postman\n2. Set up environment variables (see Environment section)\n3. Run the Authentication > Login request first to get a token\n4. The token will be automatically set for other requests\n\n**Environment Variables Required:**\n- `base_url`: http://localhost:3000 (or your server URL)\n- `token`: (will be set automatically after login)\n- `user_id`: (will be set automatically after login)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    if (response.success && response.token) {",
									"        pm.environment.set('token', response.token);",
									"        pm.environment.set('user_id', response.user._id);",
									"        pm.environment.set('user_role', response.user.role);",
									"        pm.environment.set('user_branch', response.user.branch);",
									"        console.log('✅ Login successful - Token saved');",
									"    }",
									"} else {",
									"    console.log('❌ Login failed');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"manager\",\n    \"password\": \"[YOUR_PASSWORD]\",\n    \"role\": \"manager\",\n    \"branch\": \"Maganjo\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/users/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"users",
								"login"
							]
						},
						"description": "Login with username and password. Updates environment variables with token and user info."
					}
				},
