		{
			"name": "Authentication",
			"item": [
				{
					"name": "Login - Manager",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    pm.environment.set('auth_token', response.token);",
									"    pm.environment.set('user_id', response.user._id);",
									"    pm.environment.set('user_role', response.user.role);",
									"    pm.environment.set('user_branch', response.user.branch);",
									"    console.log('Login successful, token saved');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"manager\",\n    \"password\": \"Manager@2026\",\n    \"role\": \"manager\",\n    \"branch\": \"Maganjo\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/users/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"users",
								"login"
							]
						}
					}
				},
