{
  "name": "kgl-groceries-system",
  "version": "1.0.0",
  "description": "Comprehensive web-based management system for Karibu Groceries Limited (KGL) with role-based access control, inventory management, sales tracking, and financial reporting.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seedUsers.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs kgl-api",
    "docker:build": "docker build -t kgl-groceries-system .",
    "docker:run": "docker run -p 3000:3000 --env-file .env kgl-groceries-system",
    "docker:compose": "docker-compose up -d",
    "docker:compose:down": "docker-compose down",
    "build": "echo 'No build step required for this project'",
    "postinstall": "echo 'Installation complete. Run npm run seed to create initial users.'"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mime-types": "^3.0.2",
    "mongoose": "^8.23.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.2",
    "sharp": "^0.34.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CharlesJasema/kgl-groceries-system.git"
  },
  "keywords": [
    "groceries",
    "management",
    "inventory",
    "sales",
    "nodejs",
    "express",
    "mongodb",
    "jwt",
    "api",
    "business",
    "uganda",
    "africa"
  ],
  "author": {
    "name": "Charles Jada Sebit Emmanuel",
    "email": "brocharles001@gmail.com"
  },
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/CharlesJasema/kgl-groceries-system/issues"
  },
  "homepage": "https://github.com/CharlesJasema/kgl-groceries-system#readme"
}
